# Palantir Foundry — copy to .env and fill in your values
# Get these from the Developer Console after completing the application setup

FOUNDRY_URL=https://aavya.palantirfoundry.com
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# Vanyar Ontology RID (pre-filled from the platform spec)
ONTOLOGY_RID=ri.ontology.main.ontology.2b524aaa-b15b-49c6-9b69-353f71badbaf

# JWT secret — use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-secret

# Server port
PORT=3001

# Allowed origins for CORS (comma-separated, no trailing slash)
# Use * for development, restrict in production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500
